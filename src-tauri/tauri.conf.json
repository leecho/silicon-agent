{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SiliconAgent",
  "version": "0.1.0",
  "identifier": "com.siliconagent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SiliconAgent",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 20, "y": 22 },
        "hiddenTitle": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["underWindowBackground"],
          "state": "active",
          "radius": 24
        }
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
